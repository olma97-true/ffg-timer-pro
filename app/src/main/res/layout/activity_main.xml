<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <WebView
        android:id="@+id/webView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible"
        android:focusable="false"
        android:focusableInTouchMode="false" />

    <View
        android:id="@+id/webViewOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:visibility="visible"
        android:focusable="true"
        android:focusableInTouchMode="true" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/timerContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/black"
        android:padding="16dp"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/sideQuickSets"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageButton
                android:id="@+id/btnSettings"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_preferences"
                android:contentDescription="Settings"
                android:tint="@android:color/white"
                android:layout_marginBottom="8dp" />

            <ImageButton
                android:id="@+id/btnShowSlides"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_slideshow"
                android:contentDescription="Show Slideshow"
                android:tint="@android:color/white"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnQuick1m"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:text="1m"
                android:padding="0dp"
                android:textSize="11sp"
                android:layout_marginBottom="8dp" />
            <Button
                android:id="@+id/btnQuick3m"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:text="3m"
                android:padding="0dp"
                android:textSize="11sp"
                android:layout_marginBottom="8dp" />
            <Button
                android:id="@+id/btnQuick5m"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:text="5m"
                android:padding="0dp"
                android:textSize="11sp"
                android:layout_marginBottom="8dp" />
            <Button
                android:id="@+id/btnQuick8m"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:text="8m"
                android:padding="0dp"
                android:textSize="11sp"
                android:layout_marginBottom="8dp" />
            <Button
                android:id="@+id/btnQuick10m"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:text="10m"
                android:padding="0dp"
                android:textSize="11sp"
                android:layout_marginBottom="12dp" />

            <ImageButton
                android:id="@+id/btnToggleWarning"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_lock_silent_mode_off"
                android:contentDescription="Toggle Warning Sound"
                android:tint="@android:color/white" />
        </LinearLayout>

        <ImageView
            android:id="@+id/gymLogo"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:alpha="0.8"
            android:src="@drawable/gym_logo"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:contentDescription="Gym Logo" />

        <TextView
            android:id="@+id/timerDisplay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="05:00"
            android:textColor="@android:color/white"
            android:textSize="120sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@+id/roundInfo"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed" />

        <TextView
            android:id="@+id/roundInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Round 1 / 5"
            android:textColor="@android:color/white"
            android:textSize="32sp"
            app:layout_constraintBottom_toTopOf="@+id/txtFinishTime"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/timerDisplay" />

        <TextView
            android:id="@+id/txtFinishTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Finish at 15:30"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:alpha="0.7"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@+id/quickSettings"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/roundInfo" />

        <LinearLayout
            android:id="@+id/quickSettings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintBottom_toTopOf="@+id/controls"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/txtFinishTime">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="150dp"
                    android:layout_height="wrap_content"
                    android:text="Round Length:"
                    android:textColor="@android:color/white"
                    android:textSize="18sp" />
                <Button
                    android:id="@+id/btnRoundMinus"
                    style="?android:attr/buttonStyleSmall"
                    android:layout_width="60dp"
                    android:layout_height="40dp"
                    android:background="@drawable/button_selector"
                    android:text="-"
                    android:textColor="@android:color/white" />
                <TextView
                    android:id="@+id/txtRoundLength"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="05:00"
                    android:textColor="@android:color/white"
                    android:textSize="18sp" />
                <Button
                    android:id="@+id/btnRoundPlus"
                    style="?android:attr/buttonStyleSmall"
                    android:layout_width="60dp"
                    android:layout_height="40dp"
                    android:background="@drawable/button_selector"
                    android:text="+"
                    android:textColor="@android:color/white" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="150dp"
                    android:layout_height="wrap_content"
                    android:text="Rest (sec):"
                    android:textColor="@android:color/white"
                    android:textSize="18sp" />
                <Button
                    android:id="@+id/btnRestMinus"
                    style="?android:attr/buttonStyleSmall"
                    android:layout_width="60dp"
                    android:layout_height="40dp"
                    android:background="@drawable/button_selector"
                    android:text="-"
                    android:textColor="@android:color/white" />
                <TextView
                    android:id="@+id/txtRestTime"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="60"
                    android:textColor="@android:color/white"
                    android:textSize="18sp" />
                <Button
                    android:id="@+id/btnRestPlus"
                    style="?android:attr/buttonStyleSmall"
                    android:layout_width="60dp"
                    android:layout_height="40dp"
                    android:background="@drawable/button_selector"
                    android:text="+"
                    android:textColor="@android:color/white" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="150dp"
                    android:layout_height="wrap_content"
                    android:text="Rounds:"
                    android:textColor="@android:color/white"
                    android:textSize="18sp" />
                <Button
                    android:id="@+id/btnRoundsMinus"
                    style="?android:attr/buttonStyleSmall"
                    android:layout_width="60dp"
                    android:layout_height="40dp"
                    android:background="@drawable/button_selector"
                    android:text="-"
                    android:textColor="@android:color/white" />
                <TextView
                    android:id="@+id/txtNumRounds"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="5"
                    android:textColor="@android:color/white"
                    android:textSize="18sp" />
                <Button
                    android:id="@+id/btnRoundsPlus"
                    style="?android:attr/buttonStyleSmall"
                    android:layout_width="60dp"
                    android:layout_height="40dp"
                    android:background="@drawable/button_selector"
                    android:text="+"
                    android:textColor="@android:color/white" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/controls"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/quickSettings">

            <Button
                android:id="@+id/btnStartPause"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:text="Start" />

            <Button
                android:id="@+id/btnReset"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reset" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextClock
        android:id="@+id/textClock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="16dp"
        android:format12Hour="HH:mm"
        android:format24Hour="HH:mm"
        android:textColor="@android:color/white"
        android:textSize="24sp"
        android:textStyle="bold" />

</FrameLayout>